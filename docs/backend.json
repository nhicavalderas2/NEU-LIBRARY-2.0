
{
  "entities": {
    "VisitorLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VisitorLog",
      "type": "object",
      "description": "A record of a library visit.",
      "properties": {
        "id": { "type": "string" },
        "visitorId": { "type": "string", "description": "The email or school ID used for identification." },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "college": { "type": "string" },
        "purpose": { "type": "string" },
        "userType": { "type": "string", "enum": ["Student", "Employee"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "COMPLETED"] }
      },
      "required": ["fullName", "visitorId", "timestamp", "purpose", "status", "userType"]
    },
    "BlockListEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BlockListEntry",
      "type": "object",
      "description": "A visitor who is blocked from entry.",
      "properties": {
        "id": { "type": "string" },
        "visitorName": { "type": "string" },
        "reason": { "type": "string" },
        "blockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blockedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/visitor_logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLog" },
      "description": "Records each check-in event."
    },
    "/blockList/{visitorId}": {
      "schema": { "$ref": "#/backend/entities/BlockListEntry" },
      "description": "Stores blocked visitors."
    }
  }
}
